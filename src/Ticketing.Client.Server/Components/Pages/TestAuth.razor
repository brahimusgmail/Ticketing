@page "/test-auth"
@inject HttpClient Http

<h3>Test endpoint protégé</h3>

<button class="btn btn-primary" @onclick="CallApi">
    Call API
</button>

@if (_result is not null)
{
    <pre>@_result</pre>
}

@code {
    private string? _result;

    private async Task CallApi()
    {
        try
        {
            var response = await Http.GetAsync("/api/tickets");
            _result = await response.Content.ReadAsStringAsync();
        }
        catch (Exception ex)
        {
            _result = ex.Message;
        }
    }
}
