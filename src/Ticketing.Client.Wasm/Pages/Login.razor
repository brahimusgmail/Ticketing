@page "/login"
@layout MinimalLayout
@using Ticketing.Client.Wasm.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="login-page-wasm">
    <div class="login-card-wasm">

        <h3 class="login-title">Connexion</h3>

        <EditForm Model="_model" OnValidSubmit="HandleLoginAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label>Email</label>
                <InputText @bind-Value="_model.Email"
                           class="form-control form-control-sm login-input" />
            </div>

            <div class="mb-3">
                <label>Mot de passe</label>
                <InputText @bind-Value="_model.Password"
                           type="password"
                           class="form-control form-control-sm login-input" />
            </div>

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div class="alert alert-danger">
                    @_errorMessage
                </div>
            }

            <button type="submit"
                    class="btn btn-primary login-button"
                    disabled="@_isLoading">
                @(_isLoading ? "Connexion..." : "Se connecter")
            </button>

        </EditForm>

    </div>
</div>

@code {
    private readonly LoginFormModel _model = new();
    private bool _isLoading;
    private string? _errorMessage;

    private async Task HandleLoginAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var success = await AuthService.LoginAsync(_model.Email, _model.Password);

            if (!success)
            {
                _errorMessage = "Identifiants invalides.";
                return;
            }

            Navigation.NavigateTo("/tickets");
        }
        catch
        {
            _errorMessage = "Une erreur est survenue pendant la connexion.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private sealed class LoginFormModel
    {
        public string Email { get; set; } = string.Empty;

        public string Password { get; set; } = string.Empty;
    }
}
